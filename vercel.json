{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "pnpm --filter @governance-index/index build",
  "outputDirectory": "apps/index/dist",
  "installCommand": "pnpm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [{ "source": "/((?!api|assets|.*\\..*).*)", "destination": "/index.html" }]
}
