{
  "name": "governance-index",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "preview": "pnpm --filter @governance-index/index preview",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format --write",
    "syncpack:lint": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches && syncpack format",
    "aeo:audit": "pnpm --filter @governance-index/index aeo:audit",
    "aeo:generate": "pnpm --filter @governance-index/index aeo:generate",
    "py:test": "cd packages/kgb && .venv/bin/pytest",
    "py:lint": "cd packages/kgb && .venv/bin/ruff check .",
    "py:lint:fix": "cd packages/kgb && .venv/bin/ruff check --fix .",
    "check": "pnpm syncpack:lint && pnpm lint && pnpm lint:md && pnpm typecheck && pnpm aeo:audit",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "markdownlint-cli2": "^0.22.1",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
